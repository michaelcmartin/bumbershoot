pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
-- an artificial life program by
-- bumbershoot software, 2026

-- top level program flow

cam_x=-2

function _init()
  init_sim()
end

function _update60()
  step_sim()
  if cam_x>-2 and btn(⬅️) then cam_x-=1 end
  if cam_x<24 and btn(➡️) then cam_x+=1 end
end

function _draw()
  cls()
  print("simulated evolution",26,0,10)
  print("population: "..#bugs,0,120,7)
  print("⬅️➡️\f7 to scroll",72,120,12)
  camera(cam_x,-12)
  rectfill(-2,-2,151,101,6)
  map(0,0,0,0,19,13)
  for bug in all(bugs) do
    rectfill(bug.x,bug.y,bug.x+2,bug.y+2,15)
  end
  camera()
end

menuitem(1|0x300,"new simulation",_init)
menuitem(2,"garden: on",
  function()
    garden=not garden
    menuitem(nil,"garden: "..(garden and "on" or "off"))
    return true
  end)

-->8
-- core simulation functions

xmove = {0,2, 2, 0,-2,-2}
ymove = {2,1,-1,-2,-1, 1}
garden = true
gt=0

function normalize_genes(genome)
  local m=genome[1]
  for g in all(genome) do
    m=min(m,g)
  end
  for i=1,#genome do
    genome[i]=min(genome[i]-m,13)
  end
end

function init_sim()
  bugs={}
  cycles=0
  clean_petri_dish()
  for i=1,100 do
    create_plankton(rnd(150),rnd(100))
  end
  for i=1,10 do
    genome={}
    for j=1,6 do genome[j]=rnd(10)\1 end
    normalize_genes(genome)
    bugs[i]={x=rnd(148)\1,y=rnd(98)\1,fuel=40,age=0,d=rnd(6)\1,g=genome}
  end
end

function step_sim()
  local died={}
  local born={}
  gt+=1
  for i,bug in pairs(bugs) do
    -- bug eats
    bug.fuel=min(bug.fuel+40*eat_plankton(bug.x,bug.y),1500)

    -- bug selects move
    local roll=0
    for g in all(bug.g) do
      roll+=1<<(g-1)
    end
    roll=rnd(roll)
    local choice
    for j,g in pairs(bug.g) do
      local target=1<<(g-1)
      if roll<target do
        choice=j
        break
      end
      roll-=target
    end
    -- print("dir selected:"..choice)
    bug.d=(bug.d+choice-1)%6
    bug.x=mid(0,bug.x+xmove[bug.d+1],147)
    bug.y=mid(0,bug.y+ymove[bug.d+1],97)
    -- aging
    bug.fuel-=1
    bug.age=min(bug.age+1,2000)
    -- starvation and fission
    if bug.fuel<=0 then
      -- print(gt..": bug #"..i.." starves")
      add(died,i)
    elseif bug.fuel>=1000 and bug.age>=800 and #bugs<100 then
      -- print(gt..": bug #"..i.." fissions")
      bug.age=0
      bug.fuel = bug.fuel\2
      local newbug={x=bug.x,y=bug.y,d=bug.d,fuel=bug.fuel,age=0,g={}}
      for j,g in pairs(bug.g) do newbug.g[j]=g end
      bug.g[rnd(6)\1+1]+=1
      newbug.g[rnd(6)\1+1]-=1
      normalize_genes(bug.g)
      normalize_genes(newbug.g)
      add(born,newbug)
    end
  end
  -- process births and deaths
  -- this differs from c version
  -- because birth tick doesn't
  -- process until next time
  for i=#died,1,-1 do deli(bugs,died[i]) end
  for i in all(born) do add(bugs,i) end
  -- replenish plankton
  create_plankton(rnd(150),rnd(100))
  if (garden) create_plankton(rnd(20)+40,rnd(20)+80)
end
-->8
-- pico-8-specific map routines

function clean_petri_dish()
  for y=0,99 do
    for x=0,149 do
      local c=scoord(x,y)
      sset(c&127,c\128,1)
    end
  end
end

function scoord(x,y)
  local char=19*(y\8)+(x\8)+1
  local cy=8*(char\16)+(y&7)
  local cx=8*(char&15)+(x&7)
  return (cy<<7)|cx
end

function create_plankton(x,y)
  local c=scoord(x,y)
  sset(c&127,c\128,11)
end

function eat_plankton(x,y)
  -- checks the 3x3 region from
  -- (x,y) to (x+2,y+2) and
  -- returns how many plankton
  -- are there; also deletes
  -- them
  local v=0
  for dx=0,2 do
    for dy=0,2 do
      local c=scoord(x+dx,y+dy)
      local sx=c&127
      local sy=c\128
      if (sget(sx,sy)==11) v+=1
      sset(sx,sy,1)
    end
  end
  return v
end

--[[
function print_bug(bug)
  for k,v in pairs(bug) do
    if k=="g" do
      local ln="genome: {"..v[1]
      for j=2,#v do ln = ln .. "," .. v[j] end
      print(ln.."}")
    else
      print(k..":"..v)
    end
  end
end
]]

